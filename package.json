{
  "name": "tournament-builder",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "npm --prefix server start",
    "dev": "vite",
    "dev:local": "concurrently -k -n frontend,api -c blue,green \"npm run dev\" \"npm run server:dev:local\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "server:dev": "npm --prefix server run dev",
    "server:dev:local": "npm --prefix server run dev:local",
    "server:build": "npm --prefix server run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.2.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.6"
  }
}
