{
  "name": "tournament-builder-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:local": "dotenv -e .env.local -- tsx watch src/index.ts",
    "prebuild": "prisma generate",
    "build": "tsc -p tsconfig.json",
    "prestart": "npm run build",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:local": "dotenv -e .env.local -- prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:deploy:local": "dotenv -e .env.local -- prisma migrate deploy",
    "prisma:reset": "prisma migrate reset",
    "prisma:reset:local": "dotenv -e .env.local -- prisma migrate reset",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:local": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "deploy:local": "npm run prisma:deploy:local && npm run db:seed:local"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@prisma/client": "^6.5.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
